// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Fields:
//   - displayName: string (required)
//   - role: string (required, enum: ['user', 'contributor', 'admin'])
//   - contributions: number (required)
//
// Collection: entries
// Fields:
//   - title: string (required)
//   - type: string (required, enum: ['character', 'map', 'mechanic', 'guide'])
//   - contentMode: string (required, enum: ['text', 'template'])
//   - currentRevisionId: string
//   - authorId: string (required)
//   - tags: list (strings)
//   - lastUpdated: timestamp
//
// Collection: revisions
// Fields:
//   - entryId: string (required)
//   - authorId: string (required)
//   - content: map (required)
//   - timestamp: timestamp (required)
//   - status: string (required, enum: ['pending', 'approved', 'rejected'])
//   - changeSummary: string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "wmglimpser@gmail.com" || 
         (userExists() && getUserData().role == 'admin'));
    }

    function isContributor() {
      return isAuthenticated() && 
        (request.auth.token.email == "wmglimpser@gmail.com" || 
         (userExists() && getUserData().role in ['contributor', 'admin']));
    }

    function isValidCharacter(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.role in ['Survivor', 'Hunter'] &&
             (data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() < 1000)) &&
             (data.description == null || (data.description is string && data.description.size() < 5000));
    }

    function isValidTraitFactor(data) {
      return data.characterId is string && data.characterId.size() > 0 &&
             data.category is string && data.category.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.effect is string && data.effect.size() > 0 && data.effect.size() < 1000 &&
             data.type in ['positive', 'negative', 'neutral'] &&
             (data.targetStat == null || (data.targetStat is string && data.targetStat.size() < 200)) &&
             (data.modifier == null || (data.modifier is string && data.modifier.size() < 100));
    }

    function isValidMap(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 2000 &&
             data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() < 1000 &&
             data.difficulty in ['Easy', 'Medium', 'Hard'] &&
             (data.resources == null || (data.resources is string && data.resources.size() < 5000));
    }

    function isValidExtension(data) {
      return data.characterId is string && data.characterId.size() > 0 &&
             data.type in ['talent', 'auxiliary'] &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             (data.imageUrl == null || data.imageUrl == "" || (data.imageUrl is string && data.imageUrl.size() < 1000));
    }

    function isValidMapResource(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             data.authorId is string && data.authorId.size() > 0 &&
             (data.mapId == null || (data.mapId is string && data.mapId.size() < 100));
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && 
        (request.resource.data.role == 'user' || 
         (request.auth.token.email == "wmglimpser@gmail.com" && request.resource.data.role == 'admin'));
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    // Entries Collection
    match /entries/{entryId} {
      allow read: if true; // Wiki is public
      allow create: if isContributor();
      allow update: if isContributor();
      allow delete: if isAdmin();
    }

    // Revisions Collection
    match /revisions/{revId} {
      allow read: if true;
      allow create: if isContributor();
      allow update: if isAdmin(); // Only admins can approve/reject
      allow delete: if isAdmin();
    }

    // Characters Collection
    match /characters/{charId} {
      allow read: if true;
      allow create: if isContributor() && isValidCharacter(request.resource.data);
      allow update: if isContributor() && isValidCharacter(request.resource.data);
      allow delete: if isAdmin();
    }

    // Trait Factors Collection
    match /trait_factors/{factorId} {
      allow read: if true;
      allow create: if isContributor() && isValidTraitFactor(request.resource.data);
      allow update: if isContributor() && isValidTraitFactor(request.resource.data);
      allow delete: if isAdmin();
    }
    // Maps Collection
    match /maps/{mapId} {
      allow read: if true;
      allow create: if isContributor() && isValidMap(request.resource.data);
      allow update: if isContributor() && isValidMap(request.resource.data);
      allow delete: if isAdmin();
    }

    // Talent Definitions Collection
    match /talent_definitions/{defId} {
      allow read: if true;
      allow create: if isContributor();
      allow update: if isContributor();
      allow delete: if isAdmin();
    }

    // Talent Tree Layout Collection
    match /talent_tree_layout/{roleId} {
      allow read: if true;
      allow create: if isContributor();
      allow update: if isContributor();
      allow delete: if isAdmin();
    }

    // User Talent Allocations Collection
    match /user_talent_allocations/{allocationId} {
      allow read, write: if isAuthenticated() && (allocationId == request.auth.uid + "_Survivor" || allocationId == request.auth.uid + "_Hunter" || isAdmin());
    }

    // Talent Builds Collection
    match /talent_builds/{buildId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Character Extensions Collection
    match /character_extensions/{extId} {
      allow read: if true;
      allow create: if isContributor() && isValidExtension(request.resource.data);
      allow update: if isContributor() && isValidExtension(request.resource.data);
      allow delete: if isAdmin();
    }

    // Map Resources Collection
    match /map_resources/{resId} {
      allow read: if true;
      allow create: if isContributor() && isValidMapResource(request.resource.data);
      allow update: if isContributor() && isValidMapResource(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
