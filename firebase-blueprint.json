{
  "entities": {
    "WikiEntry": {
      "title": "Wiki Entry",
      "description": "A core entry in the strategy hub (character, map, etc.)",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the entry" },
        "type": { "type": "string", "enum": ["character", "map", "mechanic", "guide"] },
        "contentMode": { "type": "string", "enum": ["text", "template"] },
        "currentRevisionId": { "type": "string", "description": "ID of the active revision" },
        "authorId": { "type": "string", "description": "UID of the creator" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "contentMode", "authorId"]
    },
    "Revision": {
      "title": "Entry Revision",
      "description": "A specific version of a wiki entry",
      "type": "object",
      "properties": {
        "entryId": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "object", "description": "The actual content data" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "changeSummary": { "type": "string" }
      },
      "required": ["entryId", "authorId", "content", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User account data and permissions",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "contributor", "admin"] },
        "contributions": { "type": "integer" }
      },
      "required": ["displayName", "role"]
    },
    "Character": {
      "title": "Character",
      "description": "A survivor or hunter character",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "role": { "type": "string", "enum": ["Survivor", "Hunter"] },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "skills": { "type": "array" },
        "presence": { "type": "array" },
        "traits": { "type": "array" },
        "mechanics": { "type": "array" },
        "lastUpdated": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the character record was last updated."
        }
      },
      "required": ["name", "title", "role"]
    },
    "TraitFactor": {
      "title": "Trait Factor",
      "description": "A factor that influences a specific trait category for a character",
      "type": "object",
      "properties": {
        "characterId": { "type": "string" },
        "category": { "type": "string" },
        "name": { "type": "string" },
        "effect": { "type": "string" },
        "source": { "type": "string" },
        "type": { "type": "string", "enum": ["positive", "negative", "neutral"] },
        "targetStat": { "type": "string" },
        "modifier": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["characterId", "category", "name", "effect", "type"]
    },
    "GameMap": {
      "title": "Game Map",
      "description": "A map in the game",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] },
        "resources": { "type": "string", "description": "Map resources description" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "imageUrl", "difficulty"]
    },
    "TalentDefinition": {
      "title": "Talent Definition",
      "description": "Metadata for a talent node in the talent tree",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["Survivor", "Hunter"] },
        "nodeId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "targetStat": { "type": "string" },
        "modifier": { "type": "string" },
        "effect": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "x": { "type": "number", "description": "Optional override for X coordinate" },
        "y": { "type": "number", "description": "Optional override for Y coordinate" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "nodeId", "name", "description"]
    },
    "TalentTreeLayout": {
      "title": "Talent Tree Layout",
      "description": "Layout and connections for the talent tree",
      "type": "object",
      "properties": {
        "nodes": { "type": "array" }
      },
      "required": ["nodes"]
    },
    "TalentBuild": {
      "title": "Talent Build",
      "description": "A saved talent point allocation for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["Survivor", "Hunter"] },
        "name": { "type": "string" },
        "points": { "type": "object", "description": "Map of nodeId to level" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "name", "points"]
    },
    "UserTalentAllocation": {
      "title": "User Talent Allocation",
      "description": "Real-time talent point allocation for a user",
      "type": "object",
      "properties": {
        "allocatedPoints": { "type": "object", "description": "Map of nodeId to level" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["allocatedPoints"]
    },
    "CharacterExtension": {
      "title": "Character Extension",
      "description": "Recommended talents or auxiliary traits for a character",
      "type": "object",
      "properties": {
        "characterId": { "type": "string" },
        "type": { "type": "string", "enum": ["talent", "auxiliary"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["characterId", "type", "title", "description"]
    },
    "MapResource": {
      "title": "Map Resource",
      "description": "Independent map resource data (e.g. cipher machine spawns)",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "mapId": { "type": "string", "description": "Optional ID of the map this resource belongs to" },
        "authorId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId"]
    },
    "Tag": {
      "title": "Unified Tag",
      "description": "A tag that can be applied to characters, traits, or talents",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "color": { "type": "string" },
        "affectedRole": { "type": "string", "enum": ["Survivor", "Hunter", "Both"] },
        "affectedStats": { "type": "array", "items": { "type": "string" } },
        "authorId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "affectedRole", "authorId"]
    },
    "CustomMetric": {
      "title": "Custom Metric",
      "description": "A user-defined metric that sums multiple traits for ranking",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Survivor", "Hunter"] },
        "traitLabels": { "type": "array", "items": { "type": "string" } },
        "authorId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "traitLabels", "authorId"]
    }
  },
  "firestore": {
    "entries": {
      "schema": "WikiEntry",
      "description": "Main wiki entries"
    },
    "revisions": {
      "schema": "Revision",
      "description": "History of all edits"
    },
    "users": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "characters": {
      "schema": "Character",
      "description": "Character database"
    },
    "trait_factors": {
      "schema": "TraitFactor",
      "description": "Factors influencing character traits"
    },
    "maps": {
      "schema": "GameMap",
      "description": "Game maps database"
    },
    "talent_definitions": {
      "schema": "TalentDefinition",
      "description": "Definitions for talent tree nodes"
    },
    "talent_tree_layout": {
      "schema": "TalentTreeLayout",
      "description": "Layout and connections for the talent tree"
    },
    "talent_builds": {
      "schema": "TalentBuild",
      "description": "Saved user talent builds"
    },
    "user_talent_allocations": {
      "schema": "UserTalentAllocation",
      "description": "Real-time user talent point allocations"
    },
    "character_extensions": {
      "schema": "CharacterExtension",
      "description": "Character-specific recommendations"
    },
    "map_resources": {
      "schema": "MapResource",
      "description": "Independent map resource entries"
    },
    "tags": {
      "schema": "Tag",
      "description": "Unified tag system"
    },
    "custom_metrics": {
      "schema": "CustomMetric",
      "description": "User-defined ranking metrics"
    }
  }
}
